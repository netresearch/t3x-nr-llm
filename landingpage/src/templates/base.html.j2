<!DOCTYPE html>
<html lang="{{ lang }}"{% block html_attr %}{% endblock %}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ meta.title }}</title>
  <meta name="description" content="{{ meta.description }}">
  <link rel="canonical" href="{{ canonical }}">
  {% for alt in alternates %}
  <link rel="alternate" hreflang="{{ alt.lang }}" href="{{ alt.href }}">
  {% endfor %}
  <meta name="theme-color" content="#2F99A4">
  <meta name="color-scheme" content="light dark">

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="nr-llm">
  <meta property="og:title" content="{{ meta.title }}">
  <meta property="og:description" content="{{ meta.description }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="{{ SITE_URL }}{{ url('assets/img/og-image.png') }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="nr-llm — the shared AI foundation for TYPO3">
  <meta property="og:locale" content="{{ 'de_DE' if lang == 'de' else 'en_US' }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ meta.title }}">
  <meta name="twitter:description" content="{{ meta.description }}">

  <link rel="icon" href="{{ url('assets/img/favicon.svg') }}" type="image/svg+xml">
  <link rel="preload" as="font" type="font/woff2" href="{{ url('assets/fonts/raleway-var.woff2') }}" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="{{ url('assets/fonts/open-sans-var.woff2') }}" crossorigin>
  <link rel="stylesheet" href="{{ url('assets/css/site.css') }}?v={{ ASSET_VER }}">

  <script>
    (function () { try { var t = localStorage.getItem('nrllm-theme'); if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t); } catch (e) {} })();
  </script>
  {% for b in jsonld_blocks %}
  <script type="application/ld+json">{{ b.json | safe }}</script>
  {% endfor %}
</head>
<body{% block body_class %}{% endblock %}>
  <a class="skip-link" href="#main">{{ s.skip }}</a>

  <header class="site-header">
    <div class="container site-header__inner">
      <a class="brand__logo" href="https://www.netresearch.de/" aria-label="Netresearch">
        <img src="{{ url('assets/img/netresearch-logo.svg') }}" width="44" height="44" alt="Netresearch">
      </a>
      <a class="brand" href="{{ url(lang + '/') }}">
        <span class="brand__name"><b>nr</b>-llm</span>
      </a>

      {% if show_nav %}
      <button class="icon-btn nav-toggle" type="button" data-nav-toggle aria-expanded="false" aria-controls="primary-nav" aria-label="{{ s.menuLabel }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <nav class="nav" id="primary-nav" data-nav aria-label="{{ s.tocLabel }}"{% if is_landing %} data-spy{% endif %}>
        <ul>
          <li><a href="{{ nav_prefix }}problem">{{ s.nav.problem }}</a></li>
          <li><a href="{{ nav_prefix }}solution">{{ s.nav.solution }}</a></li>
          <li><a href="{{ nav_prefix }}concepts">{{ s.nav.concepts }}</a></li>
          <li><a href="{{ nav_prefix }}dev-kickstart">{{ s.nav.dev }}</a></li>
          <li><a href="{{ url(lang + '/features/') }}">{{ s.featuresNav }}</a></li>
          <li><a href="{{ url('adr/') }}">{{ s.nav.adr }}</a></li>
          <li><a href="{{ nav_prefix }}faq">{{ s.nav.faq }}</a></li>
        </ul>
      </nav>
      {% endif %}

      <div class="search header-search" data-search hidden>
        <div class="search__field">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" width="18" height="18"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="search" data-search-input aria-label="{{ s.searchLabel }}" placeholder="{{ s.searchPlaceholder }}">
        </div>
        <ul class="search__results" data-search-results hidden></ul>
        <p class="visually-hidden" role="status" aria-live="polite" data-search-status></p>
      </div>

      <div class="header-tools">
        <div class="lang-switch" role="group" aria-label="{{ s.langLabel }}">
          <a href="{{ url('en/') }}" hreflang="en"{% if lang == 'en' %} aria-current="page"{% endif %}>EN</a>
          <a href="{{ url('de/') }}" hreflang="de"{% if lang == 'de' %} aria-current="page"{% endif %}>DE</a>
        </div>

        <button class="icon-btn theme-toggle" type="button" data-theme-toggle aria-pressed="false" aria-label="{{ s.themeLabel }}">
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main id="main" tabindex="-1">
    {% block main %}{% endblock %}
  </main>

  <footer class="site-footer">
    <div class="container site-footer__inner">
      <div class="site-footer__brand">
        <img src="{{ url('assets/img/netresearch-logo.svg') }}" width="40" height="40" alt="Netresearch" style="filter: brightness(0) invert(1);">
        <p class="site-footer__tagline">{{ brand.footer.tagline }}</p>
      </div>
      <ul class="site-footer__links">
        {% for l in brand.footer.links %}
        <li><a href="{{ l.href }}">{{ l.label }}</a></li>
        {% endfor %}
        <li><a href="{{ url(lang + '/security/') }}">{{ s.nav.security }}</a></li>
        <li><a href="https://github.com/netresearch/t3x-nr-llm">GitHub</a></li>
      </ul>
      <div class="site-footer__meta">
        <span>{{ brand.footer.copyright }} · Netresearch DTT GmbH</span>
        <span>nr-llm · GPL-2.0-or-later</span>
      </div>
    </div>
  </footer>

  <script>window.__NRLLM__ = {{ js_config | tojson }};</script>
  <script defer src="{{ url('assets/js/minisearch.min.js') }}?v={{ ASSET_VER }}"></script>
  <script defer src="{{ url('assets/js/search.js') }}?v={{ ASSET_VER }}"></script>
  <script defer src="{{ url('assets/js/ai-assistant.js') }}?v={{ ASSET_VER }}"></script>
  <script defer src="{{ url('assets/js/site.js') }}?v={{ ASSET_VER }}"></script>
</body>
</html>
