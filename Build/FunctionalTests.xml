<?xml version="1.0"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.5/phpunit.xsd"
         backupGlobals="true"
         bootstrap="FunctionalTestsBootstrap.php"
         cacheDirectory="../.Build/cache/phpunit-functional"
         cacheResult="false"
         colors="true"
         displayDetailsOnTestsThatTriggerDeprecations="true"
         displayDetailsOnTestsThatTriggerErrors="true"
         displayDetailsOnTestsThatTriggerNotices="true"
         displayDetailsOnTestsThatTriggerWarnings="true"
         failOnRisky="true"
         failOnWarning="true"
         requireCoverageMetadata="false"
>
    <testsuites>
        <testsuite name="functional">
            <directory>../Tests/Functional/</directory>
        </testsuite>
        <testsuite name="e2e-backend">
            <directory>../Tests/E2E/Backend/</directory>
        </testsuite>
    </testsuites>
    <!--
        Without <source> PHPUnit answers any coverage request with
        "No filter is configured, code coverage will not be processed" and
        writes nothing. The backend controllers are excluded from
        Build/phpunit.xml's source set precisely because they are covered
        here, so they are deliberately NOT excluded again.
    -->
    <source>
        <include>
            <directory suffix=".php">../Classes</directory>
        </include>
        <exclude>
            <directory>../Classes/Domain/Model</directory>
            <!-- Interfaces define contracts, not executable code -->
            <file>../Classes/LlmServiceManagerInterface.php</file>
            <file>../Classes/Provider/Contract/ProviderInterface.php</file>
            <file>../Classes/Provider/Contract/StreamingCapableInterface.php</file>
            <file>../Classes/Provider/Contract/ToolCapableInterface.php</file>
            <file>../Classes/Provider/Contract/VisionCapableInterface.php</file>
            <file>../Classes/Service/CacheManagerInterface.php</file>
            <file>../Classes/Service/SetupWizard/ModelDiscoveryInterface.php</file>
            <file>../Classes/Service/UsageTrackerServiceInterface.php</file>
            <file>../Classes/Specialized/Translation/TranslatorInterface.php</file>
            <file>../Classes/Specialized/Translation/TranslatorRegistryInterface.php</file>
            <!-- Empty exception classes (no custom logic) -->
            <file>../Classes/Exception/InvalidArgumentException.php</file>
            <file>../Classes/Exception/AccessDeniedException.php</file>
            <file>../Classes/Exception/ConfigurationNotFoundException.php</file>
            <file>../Classes/Exception/PromptTemplateNotFoundException.php</file>
            <file>../Classes/Provider/Exception/ProviderException.php</file>
            <file>../Classes/Provider/Exception/ProviderConnectionException.php</file>
            <file>../Classes/Provider/Exception/ProviderConfigurationException.php</file>
            <file>../Classes/Provider/Exception/ProviderResponseException.php</file>
            <file>../Classes/Provider/Exception/UnsupportedFeatureException.php</file>
            <file>../Classes/Specialized/Exception/ImageGenerationException.php</file>
            <file>../Classes/Specialized/Exception/SpeechServiceException.php</file>
            <file>../Classes/Specialized/Exception/TranslatorException.php</file>
            <!-- Enums: PHPUnit 12 cannot attribute coverage to enum classes -->
            <directory>../Classes/Domain/Enum</directory>
        </exclude>
    </source>

    <php>
        <ini name="display_errors" value="1"/>
        <env name="TYPO3_CONTEXT" value="Testing"/>
        <env name="typo3DatabaseDriver" value="pdo_sqlite"/>
    </php>
</phpunit>
