# DDEV Environment Configuration for nr_llm
# Copy to .env and adjust as needed

# Ollama LLM Model Configuration
# Default: qwen3:4b — tool-capable, ~2.5GB, needs ~4GB RAM/VRAM.
# Low-resource fallbacks (small, but NOT reliably tool-capable):
#   smollm2:135m   - 135M params, ~400MB (absolute minimum)
#   smollm2:360m   - 360M params, ~700MB (tiny)
#   qwen3:0.6b     - 600M params, ~800MB (smallest qwen3)
#   gemma3:1b      - 1B params, ~1.2GB (Google's latest)
#   qwen2.5:0.5b   - 0.5B params, ~1GB
#   qwen2.5:1.5b   - 1.5B params, ~2GB
#   phi3:mini      - 3.8B params, ~3GB
OLLAMA_MODEL=qwen3:4b
