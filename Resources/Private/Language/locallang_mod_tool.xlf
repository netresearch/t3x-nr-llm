                <source>Advanced</source>
            </trans-unit>
            <trans-unit id="playground.systemOverride">
                <source>System prompt override</source>
            </trans-unit>
            <trans-unit id="playground.systemOverride.placeholder">
                <source>Leave empty to use the configuration's system prompt</source>
            </trans-unit>
            <trans-unit id="playground.maxRounds">
                <source>Max rounds</source>
            </trans-unit>
            <trans-unit id="playground.maxTokens">
