            </trans-unit>
            <trans-unit id="playground.tab.messagesSent">
                <source>Messages sent</source>
            </trans-unit>
            <trans-unit id="playground.noToolsOffered">
                <source>No tools offered for this round.</source>
            </trans-unit>
