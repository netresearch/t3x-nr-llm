{
    "name": "netresearch/nr-llm",
    "description": "Shared AI/LLM foundation for TYPO3 — centralized provider management, encrypted API keys, and ready-to-use services for chat, translation, vision, and embeddings",
    "license": "GPL-2.0-or-later",
    "type": "typo3-cms-extension",
    "keywords": [
        "TYPO3",
        "extension",
        "LLM",
        "AI",
        "OpenAI",
        "Claude",
        "Gemini",
        "Ollama",
        "embeddings",
        "translation",
        "streaming",
        "provider-abstraction",
        "chatbot"
    ],
    "authors": [
        {
            "name": "Netresearch DTT GmbH",
            "homepage": "https://www.netresearch.de/",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/netresearch/t3x-nr-llm",
    "support": {
        "issues": "https://github.com/netresearch/t3x-nr-llm/issues",
        "source": "https://github.com/netresearch/t3x-nr-llm"
    },
    "require": {
        "php": "^8.2",
        "netresearch/nr-vault": "^0.4.0 || ^0.5.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^2.0 || ^3.0",
        "typo3/cms-core": "^13.4 || ^14.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.0",
        "fakerphp/faker": "^1.24",
        "giorgiosironi/eris": "^1.0",
        "netresearch/typo3-ci-workflows": "^1.2",
        "typo3/cms-dashboard": "^13.4 || ^14.0",
        "typo3/cms-install": "^13.4 || ^14.0"
    },
    "suggest": {
        "typo3/cms-dashboard": "Adds AI usage / cost widgets to the TYPO3 dashboard"
    },
    "autoload": {
        "psr-4": {
            "Netresearch\\NrLlm\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Netresearch\\NrLlm\\Tests\\": "Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "a9f/fractor-extension-installer": true,
            "captainhook/hook-installer": true,
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "bin-dir": ".Build/bin",
        "sort-packages": true,
        "vendor-dir": ".Build/vendor"
    },
    "extra": {
        "captainhook": {
            "config": "Build/captainhook.json"
        },
        "typo3/cms": {
            "extension-key": "nr_llm",
            "web-dir": ".Build/Web"
        }
    },
    "scripts": {
        "ci": [
            "@ci:test:php:cgl",
            "@ci:test:php:phpstan",
            "@ci:test:php:unit",
            "@ci:test:php:integration",
            "@ci:test:php:fuzzy"
        ],
        "ci:cgl": "php-cs-fixer fix",
        "ci:full": [
            "@ci",
            "@ci:test:php:functional"
        ],
        "ci:test:php:cgl": "php-cs-fixer fix --dry-run --diff",
        "ci:test:php:lint": "find Classes Configuration Tests -name '*.php' -print0 | xargs -0 -n1 -P$(nproc 2>/dev/null || echo 4) php -l >/dev/null",
        "ci:test:php:functional": "phpunit -c Build/FunctionalTests.xml",
        "ci:test:php:fuzzy": "phpunit -c Build/phpunit.xml --testsuite fuzzy",
        "ci:test:php:integration": "phpunit -c Build/phpunit.xml --testsuite integration",
        "ci:test:php:mutation": "infection --configuration=infection.json.dist --threads=4 -s --no-progress",
        "ci:test:php:mutation:ci": "infection --configuration=infection.json.dist --threads=4 --no-progress",
        "ci:test:php:phpstan": "phpstan analyse -c Build/phpstan/phpstan.neon",
        "ci:test:php:phpstan:baseline": "phpstan analyse -c Build/phpstan/phpstan.neon --generate-baseline Build/phpstan-baseline.neon",
        "ci:test:php:rector": "rector process --config Build/rector/rector.php --dry-run",
        "ci:test:php:unit": "phpunit -c Build/phpunit.xml --testsuite unit",
        "ddev:ci:full": "ddev exec 'cd /var/www/html/v14/vendor/netresearch/nr-llm && composer ci:full'",
        "ddev:test": "ddev exec 'cd /var/www/html/v14/vendor/netresearch/nr-llm && composer test'",
        "ddev:test:functional": "ddev exec 'cd /var/www/html/v14/vendor/netresearch/nr-llm && composer ci:test:php:functional'",
        "fractor": "fractor process --config Build/fractor/fractor.php",
        "fractor:dry": "fractor process --config Build/fractor/fractor.php --dry-run",
        "rector": "rector process --config Build/rector/rector.php",
        "test": "phpunit -c Build/phpunit.xml",
        "test:e2e": "npm run test:e2e"
    }
}
